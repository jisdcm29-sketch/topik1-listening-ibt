  "random_rules": {
    "question_pool_file": "./question-bank.json",
    "single_question_selection": "slot_templates의 candidate_filter에 맞는 single_questions 중에서 선택",
    "long_set_selection": "set_slot_templates마다 long_listening_sets 중에서 세트 단위 선택",
    "no_duplicate_bank_id": true,
    "no_duplicate_set_id": true,
    "no_duplicate_source_question_in_one_exam": true,
    "renumber_selected_questions_to_output_slots": true,
    "preserve_audio_url_and_image_url": true,
    "preserve_source_round_and_original_question_number": true,
    "create_answer_key_from_selected_items": true,
    "minimum_bank_recommendation": "랜덤 다양성을 확보하려면 3개 이상 회차 병합 후 사용하는 것을 권장",
    "example_pairing_rule": "출력 슬롯 번호가 아니라 선택된 source 문항의 example_audio_included/random_example_pairing_required 값에 따라 <보기>를 표시한다. <보기> 듣기가 포함된 source 문항은 랜덤 출제 위치가 바뀌어도 원래 <보기> 블록과 함께 이동해야 한다.",
    "output_slot_does_not_force_example": true
  },
